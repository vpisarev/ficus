fun recursion.fib@g0(recursion.n@g1: int): (int -> int) =
{
   if (<int>recursion.n@g1 < 2) { <int>recursion.n@g1 } else
      {
         (<(int -> int)>recursion.fib@g0((<int>recursion.n@g1 - 1)) +
            <(int -> int)>recursion.fib@g0((<int>recursion.n@g1 - 2)))
      }
}

<(int -> void)>Builtins.println@g2(<(int -> int)>recursion.fib@g0(10))
