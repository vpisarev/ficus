fun closure.make_adder@g0(closure.n@g1: int): (int -> (int -> int)) =
{
   fun closure.add@g2(closure.x@g3: int): (int -> int) = { (<int>closure.x@g3 + <int>closure.n@g1) }

   <(int -> int)>closure.add@g2
}

val closure.add10@g4: (int -> int) = <(int -> (int -> int))>closure.make_adder@g0(10)
